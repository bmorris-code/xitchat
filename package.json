{
  "name": "xitchat",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node server/signaling-server.js",
    "dev:auto": "node scripts/dev-with-auto-update.cjs",
    "// BUILD COMMANDS": "------------------------------------------------",
    "build": "vite build",
    "build:mobile": "cross-env IS_MOBILE=true vite build && node scripts/strip-mobile-apks.cjs",
    "// DEPLOYMENT SHORTCUTS": "-----------------------------------------",
    "sync": "npm run build:mobile && npx cap sync",
    "sync:ios": "npm run build:mobile && npx cap sync ios",
    "sync:android": "npm run build:mobile && npx cap sync android",
    "android": "npx cap open android",
    "release:all": "npm run sync:android && cd android && gradlew.bat assembleDebug",
    "release:apk": "npm run sync:android && cd android && gradlew.bat assembleRelease",
    "release:aab": "npm run sync:android && cd android && gradlew.bat bundleRelease",
    "auto-update-apk": "node scripts/auto-update-apk.cjs",
    "sync:apk-public": "node scripts/sync-public-apk.cjs",
    "preview": "vite preview",
    "vercel-build": "vite build"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/app-launcher": "^6.0.0",
    "@capacitor/camera": "^6.0.0",
    "@capacitor/cli": "6.6.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/geolocation": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@google/genai": "^1.34.0",
    "@noble/secp256k1": "^3.0.0",
    "@xmldom/xmldom": "^0.8.12",
    "ably": "^2.16.0",
    "groq-sdk": "^0.37.0",
    "lodash": "^4.18.1",
    "nostr-tools": "^2.19.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "ws": "^8.19.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "tar": "^7.5.10",
    "brace-expansion": "^2.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-legacy": "^6.1.1",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.19",
    "cross-env": "^10.1.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "~5.8.2",
    "vite": "^6.4.2",
    "vite-plugin-pwa": "^1.2.0"
  }
}
