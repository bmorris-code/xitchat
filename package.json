{
  "name": "xitchat",
  "private": true,
  "version": "1.0.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node server/signaling-server.js",
    "dev:auto": "node scripts/dev-with-auto-update.cjs",
    "// BUILD COMMANDS": "------------------------------------------------",
    "build": "vite build",
    "build:mobile": "cross-env IS_MOBILE=true vite build && node scripts/strip-mobile-apks.cjs",
    "// DEPLOYMENT SHORTCUTS": "-----------------------------------------",
    "sync": "npm run build:mobile && npx cap sync",
    "sync:ios": "npm run build:mobile && npx cap sync ios",
    "sync:android": "npm run build:mobile && npx cap sync android",
    "android": "npx cap open android",
    "release:all": "npm run sync:android && cd android && gradlew.bat assembleDebug",
    "release:apk": "npm run sync:android && cd android && gradlew.bat assembleRelease",
    "release:aab": "npm run sync:android && cd android && gradlew.bat bundleRelease",
    "auto-update-apk": "node scripts/auto-update-apk.cjs",
    "sync:apk-public": "node scripts/sync-public-apk.cjs",
    "preview": "vite preview",
    "vercel-build": "vite build"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.3",
    "@capacitor/app-launcher": "^6.0.4",
    "@capacitor/camera": "^6.1.3",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@capacitor/geolocation": "^6.1.1",
    "@capacitor/haptics": "^6.0.3",
    "@capacitor/ios": "^6.2.1",
    "@capacitor/keyboard": "^6.0.4",
    "@capacitor/status-bar": "^6.0.3",
    "@google/genai": "^1.51.0",
    "@noble/hashes": "^2.2.0",
    "@noble/secp256k1": "^3.1.0",
    "@xmldom/xmldom": "^0.9.10",
    "ably": "^2.21.0",
    "groq-sdk": "^0.37.0",
    "lodash": "^4.18.1",
    "nostr-tools": "^2.23.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "workbox-window": "^7.4.0",
    "ws": "^8.20.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "brace-expansion": "^2.0.3",
    "tar@6.2.1": "npm:tar@7.5.13"
  },
  "pnpm": {
    "overrides": {
      "tar": "^7.5.13",
      "serialize-javascript": "^7.0.5",
      "brace-expansion": "^2.0.3"
    },
    "ignoredBuiltDependencies": [
      "@google/genai",
      "protobufjs"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@vitejs/plugin-legacy": "^6.1.1",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.0",
    "cross-env": "^10.1.0",
    "postcss": "^8.5.13",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.8.3",
    "vite": "^6.4.2",
    "vite-plugin-pwa": "^1.2.0"
  }
}
