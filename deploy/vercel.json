{
  "version": 2,
  "name": "xitchat",
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    { "src": "/api/groq", "dest": "/api/groq.js" },
    { "src": "/api/gemini", "dest": "/api/gemini.js" },
    { "src": "/api/ably-token", "dest": "/api/ably-token.js" },
    { "src": "/(.*)", "dest": "/dist/$1" }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "api/groq.js": { "maxDuration": 15 },
    "api/gemini.js": { "maxDuration": 15 },
    "api/ably-token.js": { "maxDuration": 10 }
  }
}
