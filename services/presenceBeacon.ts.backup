// Presence Beacon Service - Mobile-Safe Discovery Layer
// Solves mobile invisibility by providing a lightweight, battery-safe presence coordination
// This is NOT a server - it's a stateless presence beacon that works within mobile constraints

export interface PresenceBeaconPeer {
  pubkey: string;
  name: string;
  handle: string;
  device: 'mobile' | 'desktop' | 'unknown';
  networks: ('webrtc' | 'nostr' | 'bluetooth' | 'wifi' | 'broadcast')[];
  rooms: string[];
  lastSeen: number;
  ttl: number; // Time to live in seconds
  signalStrength?: number;
  geohash?: string;
  capabilities: string[];
}

export interface PresenceBeaconConfig {
  endpoint: string;
  apiKey?: string;
  ttl: number; // Default TTL in seconds
  heartbeatInterval: number; // How often to ping
  maxRetries: number;
  isMobile: boolean;
}

class PresenceBeaconService {
  private config: PresenceBeaconConfig;
  private isInitialized = false;
  private isRunning = false;
  private heartbeatTimer: any = null;
  private retryCount = 0;
  private peers: Map<string, PresenceBeaconPeer> = new Map();
  private listeners: { [key: string]: ((data: any) => void)[] } = {};
  private myPresence: PresenceBeaconPeer | null = null;
  private isBackground = false;
  private visibilityState: 'visible' | 'hidden' | 'prerender' = 'visible';

  constructor() {
    // Auto-detect mobile and configure accordingly
    const isMobile = this.detectMobile();
    const isDevelopment = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1';
    
    this.config = {
      endpoint: isDevelopment ? 'http://localhost:8444/api/presence' : 'https://presence.xitchat.network/api/presence',
      ttl: isMobile ? 45 : 60, // Shorter TTL for mobile to save battery
      heartbeatInterval: isMobile ? 20000 : 15000, // Slower heartbeat for mobile
      maxRetries: 3,
      isMobile,
    };

    this.setupMobileOptimizations();
  }

  private detectMobile(): boolean {
    return /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);
  }

  private setupMobileOptimizations(): void {
    // Handle page visibility changes for battery optimization
    document.addEventListener('visibilitychange', () => {
      this.visibilityState = document.visibilityState as any;
      this.isBackground = this.visibilityState !== 'visible';
      
      if (this.isBackground && this.config.isMobile) {
        console.log('📱 App went to background, sending soft offline status');
        this.sendSoftOfflineStatus();
        this.adjustForBackground();
      } else if (!this.isBackground) {
        console.debug('📱 App came to foreground, sending immediate presence ping');
        this.sendImmediatePresencePing();
        this.adjustForForeground();
      }
    });

    // Handle page focus/blur for additional mobile detection
    window.addEventListener('focus', () => {
      if (!this.isBackground) {
        console.debug('📱 Window focused, sending immediate presence ping');
        this.sendImmediatePresencePing();
      }
    });

    window.addEventListener('blur', () => {
      }
    });

    // Handle page hide for mobile browsers
    window.addEventListener('pagehide', () => {
      if (this.config.isMobile) {
        console.log('📱 Page hiding, sending soft offline status');
        this.sendSoftOfflineStatus();
      }
    });

    // Handle page show events for mobile PWA
    window.addEventListener('pageshow', (event) => {
      if (this.config.isMobile && !event.persisted) {
        console.debug('📱 Page showing, sending immediate presence ping');
        this.sendImmediatePresencePing();
      }
    });

    // Handle beforeunload
    window.addEventListener('beforeunload', () => {
      this.clearPresence();
    });

    // Battery optimization
    if ('getBattery' in navigator) {
      (navigator as any).getBattery().then((battery: any) => {
        battery.addEventListener('levelchange', () => {
          if (battery.level < 0.2) {
            this.config.heartbeatInterval = 45000; // Very slow when battery low
            console.log('🔋 Battery low, reducing presence frequency');
          }
        });
      });
    }

    // Reduce frequency when connection is slow
    if ('connection' in navigator) {
      const connection = (navigator as any).connection;
      if (connection) {
        connection.addEventListener('change', () => {
          if (connection.saveData || connection.effectiveType === 'slow-2g' || connection.effectiveType === '2g') {
            this.config.heartbeatInterval = 30000; // Slower on slow connections
            console.log('🐌 Slow connection detected, reducing presence frequency');
          }
        });
      }
    }
  }

  private adjustForBackground() {
    // Reduce frequency when app is in background (mobile only)
    if (this.config.isMobile) {
      this.config.heartbeatInterval = 60000; // 1 minute when background
      this.config.ttl = 90; // Longer TTL when background
    }
  }

  private adjustForForeground() {
    // Restore normal frequency when app comes to foreground
    this.config.heartbeatInterval = this.config.isMobile ? 20000 : 15000;
    this.config.ttl = this.config.isMobile ? 45 : 60;
  }

  async initialize(userInfo?: { name?: string; handle?: string }): Promise<boolean> {
    try {
      console.log('🗼 Initializing Presence Beacon for mobile-safe discovery...');

      // Get user info from localStorage if not provided
      const name = userInfo?.name || localStorage.getItem('xitchat_name') || 'Anonymous';
      const handle = userInfo?.handle || localStorage.getItem('xitchat_handle') || 'anon';
      const pubkey = localStorage.getItem('xitchat_pubkey') || this.generatePubkey();

      // Create my presence record
      this.myPresence = {
        pubkey,
        name,
        handle: handle.startsWith('@') ? handle : `@${handle}`,
        device: this.config.isMobile ? 'mobile' : 'desktop',
        networks: ['nostr', 'webrtc'], // Default networks
        rooms: ['global', 'local'], // Default rooms
        lastSeen: Date.now(),
        ttl: this.config.ttl,
        capabilities: ['chat', 'radar', 'discovery']
      };

      // Test connectivity to presence endpoint
      const isReachable = await this.testConnectivity();
      if (!isReachable) {
        console.debug('🗼 Presence beacon not reachable, running in offline mode');
        this.isInitialized = true;
        // Enable offline simulation immediately if server unreachable
        setTimeout(() => this.enableOfflinePresenceSimulation(), 1000);
        return true; // Still allow initialization in offline mode
      }

      this.isInitialized = true;
      console.log('✅ Presence Beacon initialized successfully');
      return true;
    } catch (error) {
      console.error('❌ Failed to initialize Presence Beacon:', error);
      return false;
    }
  }

  private async testConnectivity(): Promise<boolean> {
    try {
      const response = await fetch(`${this.config.endpoint}/health`, {
        method: 'GET',
        headers: { 'Content-Type': 'application/json' },
        signal: AbortSignal.timeout(5000)
      });
      return response.ok;
    } catch (error) {
      console.debug('⚠️ Presence beacon server unavailable, using offline mode:', error);
      return false;
    }
  }

  async start(): Promise<void> {
    if (!this.isInitialized || !this.myPresence) {
      throw new Error('Presence Beacon must be initialized before starting');
    }

    if (this.isRunning) {
      console.debug('Presence Beacon already running');
      return;
    }

    console.log('🗼 Starting Presence Beacon heartbeat...');
    this.isRunning = true;
    this.retryCount = 0;

    // Check if we're already in offline mode
    if (this.peers.size > 0 && this.peers.has('sim_desktop_001')) {
      console.debug('🗼 Already in offline mode, skipping server connection');
      return;
    }

    // Start heartbeat
    this.startHeartbeat();
    
    // Initial presence broadcast
    await this.broadcastPresence();
  }

  async stop(): Promise<void> {
    console.log('🗼 Stopping Presence Beacon...');
    this.isRunning = false;
    
    if (this.heartbeatTimer) {
      clearInterval(this.heartbeatTimer);
      this.heartbeatTimer = null;
    }

    await this.clearPresence();
  }

  private startHeartbeat(): void {
    this.heartbeatTimer = setInterval(async () => {
      if (this.isRunning) {
        await this.broadcastPresence();
      }
    }, this.config.heartbeatInterval);
  }

  private async broadcastPresence(): Promise<void> {
    if (!this.myPresence) return;

    try {
      // Update presence with current geohash
      const geohash = this.getCurrentGeohash();
      if (geohash) {
        this.myPresence.geohash = geohash;
      }

      const payload = {
        action: 'update',
        presence: this.myPresence,
        timestamp: Date.now()
      };

      const response = await fetch(this.config.endpoint, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          ...(this.config.apiKey && { 'Authorization': `Bearer ${this.config.apiKey}` })
        },
        body: JSON.stringify(payload),
        signal: AbortSignal.timeout(8000) // Mobile-friendly timeout
      });

      if (response.ok) {
        this.retryCount = 0;
        console.debug('🗼 Presence broadcast successful');
        
        // Fetch nearby peers after successful update
        await this.fetchNearbyPeers();
      } else {
        throw new Error(`HTTP ${response.status}: ${response.statusText}`);
      }
    } catch (error) {
      this.retryCount++;
      
      if (this.retryCount >= this.config.maxRetries) {
        console.log('🗼 Max retries reached, enabling offline presence simulation');
        this.enableOfflinePresenceSimulation();
      } else {
        console.debug('⚠️ Failed to broadcast presence (will retry):', error);
      }
    }
  }

  private async fetchNearbyPeers(): Promise<void> {
    try {
      const myGeohash = this.myPresence?.geohash;
      if (!myGeohash) return;

      const response = await fetch(`${this.config.endpoint}/nearby?geohash=${myGeohash.substring(0, 5)}&limit=50`, {
        method: 'GET',
        headers: {
          'Content-Type': 'application/json',
          ...(this.config.apiKey && { 'Authorization': `Bearer ${this.config.apiKey}` })
        },
        signal: AbortSignal.timeout(5000)
      });

      if (response.ok) {
        const data = await response.json();
        const nearbyPeers: PresenceBeaconPeer[] = data.peers || [];
        
        // Update local peers cache
        const now = Date.now();
        nearbyPeers.forEach(peer => {
          // Skip if this is me
          if (peer.pubkey === this.myPresence?.pubkey) return;
          
          // Check if peer is still valid (not expired)
          if (peer.lastSeen + (peer.ttl * 1000) > now) {
            this.peers.set(peer.pubkey, peer);
          } else {
            this.peers.delete(peer.pubkey);
          }
        });

        // Clean up expired peers
        this.cleanupExpiredPeers();
        
        // Notify listeners
        this.notifyListeners('peersUpdated', Array.from(this.peers.values()));
        console.log(`🗼 Found ${nearbyPeers.length} nearby peers`);
      }
    } catch (error) {
      console.debug('Failed to fetch nearby peers:', error);
    }
  }

  private async clearPresence(): Promise<void> {
    if (!this.myPresence) return;

    try {
      await fetch(`${this.config.endpoint}/clear`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          ...(this.config.apiKey && { 'Authorization': `Bearer ${this.config.apiKey}` })
        },
        body: JSON.stringify({
          pubkey: this.myPresence.pubkey,
          timestamp: Date.now()
        }),
        signal: AbortSignal.timeout(3000)
      });
    } catch (error) {
      console.debug('Failed to clear presence:', error);
    }
  }

  private async sendImmediatePresencePing(): Promise<void> {
    if (!this.myPresence || !this.isRunning) return;

    // Check if we're in offline mode
    if (this.peers.size > 0 && this.peers.has('sim_desktop_001')) {
      console.debug('📱 Already in offline mode, skipping immediate ping');
      return;
    }

    console.debug('📱 Sending immediate presence ping (foreground)');
    
    // Update presence with immediate flag
    this.myPresence.lastSeen = Date.now();
    this.myPresence.ttl = this.config.ttl;
    
    // Add current geohash if available
    const geohash = this.getCurrentGeohash();
    if (geohash) {
      this.myPresence.geohash = geohash;
    }

    const payload = {
      action: 'update',
      presence: {
        ...this.myPresence,
        immediate: true, // Flag for immediate update
        foreground: true
      },
      timestamp: Date.now()
    };

    try {
      const response = await fetch(this.config.endpoint, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          ...(this.config.apiKey && { 'Authorization': `Bearer ${this.config.apiKey}` })
        },
        body: JSON.stringify(payload),
        signal: AbortSignal.timeout(5000) // Shorter timeout for immediate pings
      });

      if (response.ok) {
        console.debug('📱 Immediate presence ping successful');
        this.retryCount = 0;
        
        // Fetch nearby peers after successful update
        await this.fetchNearbyPeers();
      } else {
        console.debug('📱 Immediate presence ping failed:', response.status);
      }
    } catch (error) {
      console.debug('📱 Immediate presence ping error:', error);
    }
  }

  private async sendSoftOfflineStatus(): Promise<void> {
    if (!this.myPresence || !this.isRunning) return;

    console.log('📱 Sending soft offline status (background)');
    
    // Update presence with background flag
    this.myPresence.lastSeen = Date.now();
    this.myPresence.ttl = this.config.ttl;
    
    const payload = {
      action: 'update',
      presence: {
        ...this.myPresence,
        background: true, // Flag for background mode
        softOffline: true // Flag for soft offline (still discoverable but less active)
      },
      timestamp: Date.now()
    };

    try {
      const response = await fetch(this.config.endpoint, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          ...(this.config.apiKey && { 'Authorization': `Bearer ${this.config.apiKey}` })
        },
        body: JSON.stringify(payload),
        signal: AbortSignal.timeout(3000)
      });

      if (response.ok) {
        console.debug('📱 Soft offline status sent successfully');
      } else {
        console.debug('📱 Failed to send soft offline status:', response.status);
      }
    } catch (error) {
      console.debug('📱 Soft offline status error:', error);
    }
  }

  private getCurrentGeohash(): string | null {
    // Try to get geohash from realtimeRadar if available
    try {
      const radarLocation = (window as any).realtimeRadar?.myCurrentLocation;
      if (radarLocation?.geohash) {
        return radarLocation.geohash;
      }
    } catch (error) {
      // Ignore
    }

    // Fallback to a simple geohash based on approximate location
    // In a real implementation, this would use the browser's geolocation API
    return '428F'; // Default geohash for Johannesburg area
  }

  private generatePubkey(): string {
    // Generate a simple pubkey for demo purposes
    // In a real implementation, this would use proper cryptographic key generation
    return 'pub_' + Math.random().toString(36).substr(2, 16);
  }

  private cleanupExpiredPeers(): void {
    const now = Date.now();
    const expiredPeers: string[] = [];
    
    this.peers.forEach((peer, pubkey) => {
      if (peer.lastSeen + (peer.ttl * 1000) <= now) {
        expiredPeers.push(pubkey);
      }
    });

    expiredPeers.forEach(pubkey => {
      this.peers.delete(pubkey);
    });

    if (expiredPeers.length > 0) {
      console.debug(`🗼 Cleaned up ${expiredPeers.length} expired peers`);
      this.notifyListeners('peersUpdated', Array.from(this.peers.values()));
    }
  }

  // Room management
  async joinRoom(roomId: string): Promise<void> {
    if (!this.myPresence) return;

    if (!this.myPresence.rooms.includes(roomId)) {
      this.myPresence.rooms.push(roomId);
      await this.broadcastPresence();
      console.debug(`🗼 Joined room: ${roomId}`);
    }
  }

  async leaveRoom(roomId: string): Promise<void> {
    if (!this.myPresence) return;

    const index = this.myPresence.rooms.indexOf(roomId);
    if (index > -1) {
      this.myPresence.rooms.splice(index, 1);
      await this.broadcastPresence();
      console.debug(`🗼 Left room: ${roomId}`);
    }
  }

  // Public API methods
  getPeers(): PresenceBeaconPeer[] {
    return Array.from(this.peers.values());
  }

  getMyPresence(): PresenceBeaconPeer | null {
    return this.myPresence;
  }

  isConnected(): boolean {
    return this.isRunning && this.retryCount < this.config.maxRetries;
  }

  subscribe(event: string, callback: (data: any) => void): () => void {
    if (!this.listeners[event]) this.listeners[event] = [];
    this.listeners[event].push(callback);
    return () => {
      this.listeners[event] = this.listeners[event].filter(cb => cb !== callback);
    };
  }

  private notifyListeners(event: string, data: any): void {
    if (this.listeners[event]) {
      this.listeners[event].forEach(callback => callback(data));
    }
  }

  private enableOfflinePresenceSimulation(): void {
    console.log('🗼 Enabling offline presence simulation (server unavailable)');
    
    // Generate some simulated peers for testing
    const simulatedPeers: PresenceBeaconPeer[] = [
      {
        pubkey: 'sim_desktop_001',
        name: 'Desktop User',
        handle: '@desktop',
        device: 'desktop',
        networks: ['webrtc', 'nostr'],
        rooms: ['global', 'local'],
        lastSeen: Date.now(),
        ttl: 60,
        signalStrength: 100,
        geohash: this.myPresence?.geohash || 'default',
        capabilities: ['chat', 'radar', 'discovery']
      },
      {
        pubkey: 'sim_mobile_001',
        name: 'Mobile User',
        handle: '@mobile',
        device: 'mobile',
        networks: ['nostr'],
        rooms: ['global'],
        lastSeen: Date.now() - 30000, // 30 seconds ago
        ttl: 45,
        signalStrength: 80,
        geohash: this.myPresence?.geohash || 'default',
        capabilities: ['chat', 'discovery']
      }
    ];

    // Add simulated peers to the store
    simulatedPeers.forEach(peer => {
      this.peers.set(peer.pubkey, peer);
    });

    // Notify listeners about simulated peers
    this.notifyListeners('peersUpdated', Array.from(this.peers.values()));
    
    // Continue heartbeat but with longer intervals
    this.config.heartbeatInterval = 60000; // 1 minute in offline mode
    
    console.log(`🗼 Added ${simulatedPeers.length} simulated peers for offline testing`);
  }
}

export const presenceBeacon = new PresenceBeaconService();
